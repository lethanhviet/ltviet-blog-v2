---
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
---

<Layout>
  <MetaPage slot="head" />
  <section class="page-intro" aria-labelledby="home-greeting">
    <h1 id="home-greeting" class="page-title" data-greeting>Hello</h1>
    <prose-content>
      <p>I'm Viet. 👋</p>
      <p>
        I build industrial robotics 🤖 and manufacturing systems—real-world
        automation that powers modern factories.
      </p>
      <p>
        Previously, I worked in banking and finance, focused on corporate
        lending and capital financing.
      </p>
      <p>
        You'll also likely find me waitering tables and talking to random
        strangers at
        <a href="https://maps.app.goo.gl/RCQeb1NXjn82n1jn9" target="_blank" rel="noopener noreferrer">Ai Izakaya</a>
        or
        <a href="https://maps.app.goo.gl/MLYB2SFwL4q8vgww8" target="_blank" rel="noopener noreferrer">Sake Labo</a>.
      </p>
      <p>
        In my free time, I read about business, economics, technology, history,
        and politics. I also enjoy travel, good food & drink, great coffee, and
        learning about different cultures.
      </p>
      <p>
        This is my personal experimental playground for exploring ideas,
        obsessions, and the occasional rabbit 🐰 holes.
      </p>
    </prose-content>
  </section>
</Layout>

<script>
  const getGreeting = (hour: number) => {
    if (hour >= 18) return "Good evening"
    if (hour >= 12) return "Good afternoon"
    if (hour >= 5) return "Good morning"
    if (hour >= 3) return "It's late, go to bed"
    return "Hello"
  }

  const greeting = document.querySelector<HTMLElement>("[data-greeting]")

  if (greeting) {
    greeting.textContent = getGreeting(new Date().getHours())
  }
</script>
