---
import MetaPage from "@/components/MetaPage.astro"
import PostCard from "@/components/writing/PostCard.astro"
import Layout from "@/layouts/Layout.astro"
import { getTags, type WritingEntry } from "@/lib/content"

export async function getStaticPaths() {
  const tags = await getTags()
  return [...tags].map(([tag, posts]) => ({
    params: { id: tag },
    props: { tag, posts },
  }))
}

type Props = { tag: string; posts: WritingEntry[] }

const { tag, posts } = Astro.props
---

<Layout>
  <MetaPage
    slot="head"
    title={`Posts tagged "${tag}"`}
    description={`A collection of posts tagged with ${tag}.`}
    noindex
  />
  <ul>
    {posts.map((post) => <PostCard post={post} />)}
  </ul>
</Layout>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }
</style>
