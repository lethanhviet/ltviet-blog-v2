---
import MetaPost from "@/components/MetaPost.astro"
import PostActions from "@/components/PostActions.astro"
import ScrollToTop from "@/components/ScrollToTop.astro"
import SeriesReader from "@/components/SeriesReader.astro"
import Layout from "@/layouts/Layout.astro"
import { getPosts, getSubposts, pageTitle } from "@/lib/content"
import { formatDate, isSubpost, subpostSlug } from "@/lib/utils"
import { Image } from "astro:assets"
import { render, type CollectionEntry } from "astro:content"

export async function getStaticPaths() {
  const posts = await getPosts()
  const series = await getSubposts()
  return posts.flatMap((parent, i) => {
    const chain = [parent, ...(series.get(parent.id) ?? [])]
    return chain.map((post) => ({
      params: { id: post.id },
      props: { post, chain, prev: posts[i + 1], next: posts[i - 1] },
    }))
  })
}

type Props = {
  post: CollectionEntry<"writing">
  chain: CollectionEntry<"writing">[]
  prev?: CollectionEntry<"writing">
  next?: CollectionEntry<"writing">
}

const { post, chain, prev, next } = Astro.props
const [parent] = chain
const rendered = await Promise.all(
  chain.map(async (entry) => ({
    entry,
    ...(await render(entry)),
  })),
)

---

<Layout>
  <MetaPost
    slot="head"
    post={post}
    canonical={isSubpost(post.id) ? `/writing/${parent.id}` : undefined}
  />
  <PostActions slot="actions" prev={prev} next={next} />
  <ScrollToTop floating />
  {rendered.map(({ entry, Content }, i) => (
      <article
        id={i === 0 ? undefined : subpostSlug(entry.id)}
        data-url={`/writing/${entry.id}`}
        data-title={pageTitle(entry.data.title)}
        data-embedded={i > 0 || undefined}
      >
        <header>
          <h1>{entry.data.title}</h1>
          <time datetime={entry.data.date.toISOString()}
            >{formatDate(entry.data.date)}</time
          >
        </header>
        {entry.data.image && (
          <post-banner>
            <Image
              src={entry.data.image}
              alt={entry.data.title}
              width={1200}
              height={630}
              priority={entry.id === post.id || undefined}
            />
          </post-banner>
        )}
        <prose-content>
          <Content />
        </prose-content>
      </article>
    ))}
  {chain.length > 1 && <SeriesReader />}
</Layout>

<style>
  article[data-embedded] {
    margin-block-start: var(--space-xl);
    padding-block-start: var(--space-xl);
    border-block-start: 2px solid var(--border);
    scroll-margin-block-start: calc(-2px - 0.2 * var(--step-2));

    header h1 {
      font-size: var(--step-2);
    }
  }

  header {
    margin-block-end: var(--space-m);

    h1 {
      font-size: var(--step-3);
      line-height: calc(var(--leading-offset) + 1em);
      font-weight: var(--font-weight-medium);
    }

    time {
      display: block;
      margin-block-start: var(--space-3xs);
      font-size: var(--step--1);
      color: var(--muted-foreground);
    }
  }

  post-banner {
    display: block;
    margin-block-end: var(--space-m);

    :global(img) {
      inline-size: 100%;
      block-size: auto;
    }
  }
</style>
