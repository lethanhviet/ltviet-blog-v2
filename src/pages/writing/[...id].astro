---
import MetaPost from "@/components/MetaPost.astro"
import ScrollToTop from "@/components/ScrollToTop.astro"
import PostActions from "@/components/writing/PostActions.astro"
import PostArticle from "@/components/writing/PostArticle.astro"
import SeriesReader from "@/components/writing/SeriesReader.astro"
import Layout from "@/layouts/Layout.astro"
import { getWritingPagePaths, type WritingPageProps } from "@/lib/content"
import { isSubpost, writingPath } from "@/lib/utils"

export async function getStaticPaths() {
  return getWritingPagePaths()
}

const { post, chain, previous, next } = Astro.props as WritingPageProps
const [parent] = chain
---

<Layout>
  <MetaPost
    slot="head"
    post={post}
    canonical={isSubpost(post.id) ? writingPath(parent.id) : undefined}
  />
  <PostActions slot="actions" previous={previous} next={next} />
  <ScrollToTop floating />
  {chain.map((entry, index) => (
      <PostArticle
        post={entry}
        embedded={index > 0}
        priority={entry.id === post.id}
      />
    ))}
  {chain.length > 1 && <SeriesReader />}
</Layout>
