---
import BookList from "@/components/BookList.astro"
import LibraryStats from "@/components/LibraryStats.astro"
import LibraryTabs from "@/components/LibraryTabs.astro"
import LibraryTagFilter from "@/components/LibraryTagFilter.astro"
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
import {
  getBookFullList,
  getCurrentlyReadingBooks,
  getFavoriteBooks,
} from "@/lib/content"

const favorites = await getFavoriteBooks()
const reading = await getCurrentlyReadingBooks()
const fullList = await getBookFullList()

const totalFinishedBooks = fullList.years.reduce(
  (sum, [, books]) => sum + books.length,
  0,
)
const totalYears = fullList.years.length

const tabs = [
  { id: "favorites", label: "Favorites" },
  { id: "reading", label: "Currently Reading" },
  { id: "finished", label: "Finished" },
  { id: "bucketlist", label: "Bucket List" },
  { id: "dnf", label: "DNF" },
]

const yearTabs = fullList.years.map(([year, books]) => ({
  id: `year-${year}`,
  label: `${year} (${books.length})`,
}))
---

<Layout>
  <MetaPage
    slot="head"
    title="Library"
    description="Books I've read, am reading, and plan to read."
  />
  <library-intro>
    <h1>Too many books, too little time...</h1>
    <prose-content>
      <p>
        {totalFinishedBooks}
        books in the last {totalYears} years.
      </p>
      <blockquote>
        <p>
          In my whole life, I have known no wise people (over a broad subject
          matter area) who didn't read all the time—none, zero. You'd be amazed
          at how much Warren reads—and at how much I read. My children laugh at
          me. They think I'm a book with a couple of legs sticking out.
        </p>
        <p>— Charlie Munger</p>
      </blockquote>
    </prose-content>
  </library-intro>

  <LibraryTabs tabs={tabs}>
    <div role="tabpanel" id="panel-favorites" aria-labelledby="tab-favorites">
      <BookList books={favorites} showDescription />
    </div>
    <div
      role="tabpanel"
      id="panel-reading"
      aria-labelledby="tab-reading"
      hidden
    >
      <BookList books={reading} showTags />
    </div>
    <div
      role="tabpanel"
      id="panel-finished"
      aria-labelledby="tab-finished"
      hidden
    >
      <LibraryTabs tabs={yearTabs} variant="pill">
        {fullList.years.map(([year, books], i) => (
          <div
            role="tabpanel"
            id={`panel-year-${year}`}
            aria-labelledby={`tab-year-${year}`}
            hidden={i > 0}
          >
            <LibraryStats books={books} />
            <LibraryTagFilter books={books} />
            <BookList books={books} showRating />
          </div>
        ))}
      </LibraryTabs>
    </div>
    <div
      role="tabpanel"
      id="panel-bucketlist"
      aria-labelledby="tab-bucketlist"
      hidden
    >
      <BookList books={fullList.bucketlist} showTags />
    </div>
    <div role="tabpanel" id="panel-dnf" aria-labelledby="tab-dnf" hidden>
      <BookList books={fullList.dnf} showTags />
    </div>
  </LibraryTabs>
</Layout>

<style>
  library-intro {
    display: block;
    margin-block-end: var(--space-l);

    @media (width >= 64rem) {
      margin-block-start: -0.2em;
    }

    h1 {
      font-size: var(--step-3);
      line-height: calc(var(--leading-offset) + 1em);
      font-weight: var(--font-weight-medium);
      color: var(--foreground);
      margin-block-end: var(--space-m);
    }
  }
</style>
