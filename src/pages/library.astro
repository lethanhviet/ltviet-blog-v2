---
import LibraryCatalog from "@/components/library/LibraryCatalog.astro"
import LibraryIntro from "@/components/library/LibraryIntro.astro"
import MetaPage from "@/components/MetaPage.astro"
import Layout from "@/layouts/Layout.astro"
import { getLibraryBooks } from "@/lib/content"

const library = await getLibraryBooks()

const totalFinishedBooks = library.years.reduce(
  (sum, [, books]) => sum + books.length,
  0,
)
const totalYears = library.years.length
---

<Layout>
  <MetaPage
    slot="head"
    title="Library"
    description="Too many books, too little time..."
  />
  <LibraryIntro
    totalFinishedBooks={totalFinishedBooks}
    totalYears={totalYears}
  />
  <LibraryCatalog library={library} />
</Layout>
