---
import { SITE } from "@/consts"

type Props = {
  title: string
  documentTitle: string
  description: string
  canonical: URL
  image: URL
  url?: URL
  type?: "website" | "article"
  noindex?: boolean
  authors?: string[]
  publishedAt?: Date
}

const {
  title,
  documentTitle,
  description,
  canonical,
  image,
  url = canonical,
  type = "website",
  noindex = false,
  authors = [],
  publishedAt,
} = Astro.props
---

<title>{documentTitle}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
{noindex && <meta name="robots" content="noindex, nofollow" />}

<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content={type}>
<meta property="og:url" content={url}>
<meta property="og:site_name" content={SITE.title}>
<meta property="og:locale" content={SITE.locale.replace("-", "_")}>
<meta property="og:image" content={image}>
<meta property="og:image:alt" content={title}>

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={image}>
<meta name="twitter:image:alt" content={title}>
{authors.length > 0 && (
    <meta name="twitter:creator" content={authors.join(", ")} />
  )}

{publishedAt && (
  <meta property="article:published_time" content={publishedAt.toISOString()} />
)}
{authors.map((author) => <meta property="article:author" content={author} />)}
