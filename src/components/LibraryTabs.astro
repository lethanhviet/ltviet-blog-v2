---
type Tab = { id: string; label: string }
type Props = { tabs: Tab[]; variant?: "underline" | "pill" }

const { tabs, variant = "underline" } = Astro.props
---

<library-tabs>
  <div role="tablist" data-variant={variant}>
    {tabs.map((tab, i) => (
      <button
        type="button"
        role="tab"
        id={`tab-${tab.id}`}
        aria-controls={`panel-${tab.id}`}
        aria-selected={i === 0}
        data-tab={tab.id}
      >
        {tab.label}
      </button>
    ))}
  </div>
  <slot />
</library-tabs>

<style>
  [role="tablist"] {
    display: flex;
    gap: var(--space-m);
    overflow-x: auto;
    overflow-y: hidden;
    border-block-end: 2px solid var(--border);
    margin-block-end: var(--space-m);
    scrollbar-width: none;

    &::-webkit-scrollbar {
      display: none;
    }
  }

  [role="tab"] {
    appearance: none;
    flex-shrink: 0;
    padding-block: var(--space-2xs);
    font-size: var(--step-0);
    font-weight: var(--font-weight-medium);
    color: var(--muted-foreground);
    background-color: transparent;
    border: none;
    border-block-end: 2px solid transparent;
    cursor: pointer;

    &:hover {
      color: var(--foreground);
    }

    &[aria-selected="true"] {
      color: var(--foreground);
      border-block-end-color: var(--foreground);
    }
  }

  [role="tablist"][data-variant="pill"] {
    flex-wrap: wrap;
    gap: var(--space-3xs);
    border-block-end: none;
    margin-block-end: var(--space-s);

    [role="tab"] {
      padding: var(--space-3xs) var(--space-xs);
      font-size: var(--step--1);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);

      &:hover {
        background-color: var(--muted);
      }

      &[aria-selected="true"] {
        color: var(--primary-foreground);
        background-color: var(--primary);
        border-color: var(--primary);
      }
    }
  }
</style>

<script>
  class LibraryTabs extends HTMLElement {
    connectedCallback() {
      const tablist = this.querySelector<HTMLElement>(':scope > [role="tablist"]')
      const tabs = [
        ...(tablist?.querySelectorAll<HTMLButtonElement>('[role="tab"]') ?? []),
      ]
      const panels = tabs.map((tab) =>
        document.getElementById(tab.getAttribute("aria-controls") ?? ""),
      )
      const isTopLevel = tablist?.dataset.variant !== "pill"

      const activate = (index: number, updateHash: boolean) => {
        tabs.forEach((t, j) => {
          t.setAttribute("aria-selected", String(j === index))
          const panel = panels[j]
          if (panel) panel.hidden = j !== index
        })
        if (updateHash && isTopLevel) {
          history.replaceState(null, "", `#${tabs[index].dataset.tab}`)
        }
      }

      tabs.forEach((tab, i) => {
        tab.addEventListener("click", () => activate(i, true))
      })

      if (isTopLevel) {
        const syncFromHash = () => {
          const slug = decodeURIComponent(location.hash.replace(/^#/, ""))
          if (!slug) return
          const index = tabs.findIndex((t) => t.dataset.tab === slug)
          if (index !== -1) activate(index, false)
        }
        syncFromHash()
        window.addEventListener("hashchange", syncFromHash)
      }
    }
  }

  customElements.define("library-tabs", LibraryTabs)
</script>
