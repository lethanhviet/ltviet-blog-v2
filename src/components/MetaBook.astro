---
import { pageTitle } from "@/consts"
import MetaTags from "@/components/MetaTags.astro"
import type { BookEntry } from "@/lib/content"

type Props = {
  book: BookEntry
}

const { book } = Astro.props
const { title, author, description, cover } = book.data

const base = Astro.site ?? new URL(Astro.url.origin)
const url = new URL(Astro.url.pathname, base)
const ogImage = new URL(cover.src, base)
---

<MetaTags
  title={title}
  documentTitle={pageTitle(title)}
  description={description}
  canonical={url}
  image={ogImage}
  url={url}
  type="article"
  authors={[author]}
/>
