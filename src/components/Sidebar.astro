---
import CloseIcon from "@/assets/icons/close.svg"
import MenuIcon from "@/assets/icons/menu.svg"
import Logo from "@/assets/logo.svg"
import ThemeToggle from "@/components/ThemeToggle.astro"
import { NAV_GROUPS, SITE } from "@/consts"
import { normalizePath } from "@/lib/utils"

const pathname = normalizePath(Astro.url.pathname) || "/"
---

<aside data-bar>
  <button
    data-icon-button
    data-menu-toggle
    aria-label="Toggle menu"
    aria-expanded="false"
    aria-controls="mobile-nav"
  >
    <menu-icon><MenuIcon aria-hidden="true" /></menu-icon>
    <close-icon><CloseIcon aria-hidden="true" /></close-icon>
  </button>
  <sidebar-inner>
    <a href="/" aria-label={SITE.title}>
      <Logo />
      <span>{SITE.title}</span>
    </a>
    <nav id="mobile-nav">
      {NAV_GROUPS.map((group) => (
          <ul>
            {group.label && <li data-group-label>{group.label}</li>}
            {group.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={
                      !item.external && pathname === item.href
                        ? "page"
                        : undefined
                    }
                    target={item.external ? "_blank" : undefined}
                    rel={item.external ? "noopener noreferrer" : undefined}
                  >
                    <item.icon aria-hidden="true" />
                    <span>{item.label}</span>
                  </a>
                </li>
              ))}
          </ul>
        ))}
    </nav>
  </sidebar-inner>
  <sidebar-toggle>
    <ThemeToggle />
    <slot name="actions" />
  </sidebar-toggle>
</aside>

<style>
  aside {
    position: sticky;
    top: var(--page-offset-top);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: calc(100svh - var(--page-offset-top) - var(--page-offset-bottom));

    @media (width < 64rem) {
      position: relative;
      top: auto;
      height: auto;
      flex-direction: row;
      align-items: center;
      gap: var(--space-s);
    }
  }

  sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    min-height: 0;

    > a {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      width: fit-content;
      flex-shrink: 0;
      font-weight: var(--font-weight-medium);
      font-size: var(--step-0);
      color: var(--foreground);
      text-decoration-line: none;

      svg {
        inline-size: 1.125rem;
        block-size: 1.125rem;
        flex-shrink: 0;

        @media (width < 64rem) {
          display: none;
        }
      }
    }

    @media (width < 64rem) {
      flex: 1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      min-width: 0;
    }
  }

  nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: none;

    &::-webkit-scrollbar {
      display: none;
    }

    @media (width < 64rem) {
      position: absolute;
      inset-inline: calc(-1 * var(--bar-gutter));
      top: 100%;
      z-index: 10;
      max-height: calc(100svh - 100% - var(--space-m));
      padding: var(--space-xs) var(--bar-gutter) var(--space-s);
      background-color: var(--background);
      border-block-end: 2px solid var(--border);
      box-shadow: 0 12px 24px -12px rgb(0 0 0 / 0.2);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(-0.5rem);
      transition:
        opacity 0.2s ease,
        transform 0.2s ease,
        visibility 0.2s;
    }
  }

  aside[data-menu-open] nav {
    @media (width < 64rem) {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateY(0);
    }
  }

  nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  nav ul:has(li[data-group-label]) a {
    font-size: var(--step--1);
  }

  li[data-group-label] {
    padding-inline: var(--space-2xs);
    margin-block-end: var(--space-3xs);
    font-size: var(--step--2);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  nav a {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-3xs) var(--space-2xs);
    border-radius: var(--radius-md);
    color: var(--muted-foreground);
    text-decoration-line: none;

    > svg:first-child {
      flex-shrink: 0;
      inline-size: 1em;
      block-size: 1em;
    }

    > span {
      flex: 1;
      min-width: 0;
    }

    &:hover,
    &[aria-current="page"] {
      color: var(--foreground);
      background-color: var(--muted);
    }
  }

  sidebar-toggle {
    display: flex;
    align-items: center;
    margin-inline-start: -0.5rem;

    @media (width < 64rem) {
      margin-inline-start: 0;
      margin-inline-end: -0.5rem;
    }
  }

  [data-menu-toggle] {
    display: none;

    @media (width < 64rem) {
      display: inline-flex;
    }
  }

  close-icon {
    display: none;
  }

  aside[data-menu-open] {
    menu-icon {
      display: none;
    }

    close-icon {
      display: inline-flex;
    }
  }
</style>

<script>
  const aside = document.querySelector<HTMLElement>("[data-bar]")
  const toggle = document.querySelector<HTMLElement>("[data-menu-toggle]")
  const nav = aside?.querySelector("nav")

  if (aside && toggle && nav) {
    const closeMenu = () => {
      aside.removeAttribute("data-menu-open")
      toggle.setAttribute("aria-expanded", "false")
    }

    toggle.addEventListener("click", () => {
      const open = aside.hasAttribute("data-menu-open")
      aside.toggleAttribute("data-menu-open", !open)
      toggle.setAttribute("aria-expanded", String(!open))
    })

    nav.addEventListener("click", (event) => {
      if ((event.target as Element).closest("a")) closeMenu()
    })

    document.addEventListener("click", (event) => {
      if (
        aside.hasAttribute("data-menu-open") &&
        !aside.contains(event.target as Node)
      )
        closeMenu()
    })

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu()
    })
  }
</script>
