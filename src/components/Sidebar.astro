---
import Logo from "@/assets/logo.svg"
import ThemeToggle from "@/components/ThemeToggle.astro"
import { NAV_GROUPS, SITE } from "@/consts"
import { normalizePath } from "@/lib/utils"

const pathname = normalizePath(Astro.url.pathname) || "/"
---

<aside data-bar>
  <sidebar-inner>
    <a href="/" aria-label={SITE.title}>
      <Logo />
      <span>{SITE.title}</span>
    </a>
    <nav>
      {NAV_GROUPS.map((group) => (
          <ul>
            {group.label && <li data-group-label>{group.label}</li>}
            {group.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={
                      !item.external && pathname === item.href
                        ? "page"
                        : undefined
                    }
                    target={item.external ? "_blank" : undefined}
                    rel={item.external ? "noopener noreferrer" : undefined}
                  >
                    <item.icon aria-hidden="true" />
                    <span>{item.label}</span>
                  </a>
                </li>
              ))}
          </ul>
        ))}
    </nav>
  </sidebar-inner>
  <sidebar-toggle>
    <ThemeToggle />
    <slot name="actions" />
  </sidebar-toggle>
</aside>

<style>
  aside {
    position: sticky;
    top: var(--page-offset-top);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: calc(100svh - var(--page-offset-top) - var(--page-offset-bottom));

    @media (width < 64rem) {
      position: static;
      height: auto;
      flex-direction: row;
      align-items: center;
      gap: var(--space-s);
    }
  }

  sidebar-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    min-height: 0;

    > a {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      width: fit-content;
      flex-shrink: 0;
      font-weight: var(--font-weight-medium);
      font-size: var(--step-0);
      color: var(--foreground);
      text-decoration-line: none;

      svg {
        inline-size: 1.125rem;
        block-size: 1.125rem;
        flex-shrink: 0;
      }

      @media (width < 26rem) {
        span {
          display: none;
        }
      }
    }

    @media (width < 64rem) {
      flex: 1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      min-width: 0;
    }
  }

  nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: none;

    &::-webkit-scrollbar {
      display: none;
    }

    @media (width < 64rem) {
      flex-direction: row;
      align-items: center;
      gap: var(--space-2xs);
      overflow-x: auto;
      overflow-y: visible;
    }
  }

  nav ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);

    @media (width < 64rem) {
      flex-direction: row;
      align-items: center;
      gap: var(--space-2xs);
    }
  }

  nav ul:has(li[data-group-label]) {
    a {
      font-size: var(--step--1);
    }

    @media (width < 64rem) {
      display: none;
    }
  }

  li[data-group-label] {
    padding-inline: var(--space-2xs);
    margin-block-end: var(--space-3xs);
    font-size: var(--step--2);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--muted-foreground);

    @media (width < 64rem) {
      display: none;
    }
  }

  nav a {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-3xs) var(--space-2xs);
    border-radius: var(--radius-md);
    color: var(--muted-foreground);
    text-decoration-line: none;

    > svg:first-child {
      flex-shrink: 0;
      inline-size: 1em;
      block-size: 1em;
    }

    > span {
      flex: 1;
      min-width: 0;
    }

    &:hover,
    &[aria-current="page"] {
      color: var(--foreground);
      background-color: var(--muted);
    }

    @media (width < 64rem) {
      padding: var(--space-3xs);

      > span {
        display: none;
      }
    }
  }

  sidebar-toggle {
    display: flex;
    align-items: center;
    margin-inline-start: -0.5rem;

    @media (width < 64rem) {
      margin-inline-start: 0;
      margin-inline-end: -0.5rem;
    }
  }
</style>
