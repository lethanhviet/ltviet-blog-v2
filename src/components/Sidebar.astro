---
import CloseIcon from "@/assets/icons/close.svg"
import MenuIcon from "@/assets/icons/menu.svg"
import Logo from "@/assets/logo.svg"
import ThemeToggle from "@/components/ThemeToggle.astro"
import { NAV_GROUPS, SITE, type NavItem } from "@/consts"
import { normalizePath } from "@/lib/utils"

const pathname = normalizePath(Astro.url.pathname) || "/"

const matchesPath = (path: string, target: string) =>
  target === "/"
    ? path === target
    : path === target || path.startsWith(`${target}/`)

const isActive = ({ external, href, activePrefixes }: NavItem) => {
  if (external) return false
  if (matchesPath(pathname, href)) return true
  return (activePrefixes ?? []).some((prefix) => matchesPath(pathname, prefix))
}
---

<aside class="sidebar" data-sidebar>
  <button
    type="button"
    data-icon-button
    data-menu-toggle
    aria-label="Open navigation"
    aria-expanded="false"
    aria-controls="primary-navigation"
  >
    <span class="menu-icon"><MenuIcon aria-hidden="true" /></span>
    <span class="close-icon"><CloseIcon aria-hidden="true" /></span>
  </button>
  <div class="sidebar__inner">
    <a class="sidebar__brand" href="/" aria-label={SITE.title}>
      <Logo />
      <span>{SITE.title}</span>
    </a>
    <nav id="primary-navigation" aria-label="Primary navigation">
      {NAV_GROUPS.map((group) => (
        <section class="nav-group" aria-label={group.label}>
          {group.label && <h2>{group.label}</h2>}
          <ul>
            {group.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={isActive(item) ? "page" : undefined}
                  target={item.external ? "_blank" : undefined}
                  rel={item.external ? "noopener noreferrer" : undefined}
                >
                  <item.icon aria-hidden="true" />
                  <span>{item.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </nav>
  </div>
  <div class="sidebar__actions">
    <ThemeToggle />
    <slot name="actions" />
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: var(--page-offset-top);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: calc(100svh - var(--page-offset-top) - var(--page-offset-bottom));

    @media (width < 64rem) {
      position: relative;
      top: auto;
      height: auto;
      flex-direction: row;
      align-items: center;
      gap: var(--space-s);
      padding-block: var(--space-s);
      padding-inline: var(--bar-gutter);
      background-color: color-mix(in oklab, var(--background) 90%, transparent);
      backdrop-filter: blur(var(--blur-sm));
    }
  }

  .sidebar__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    min-height: 0;

    @media (width < 64rem) {
      flex: 1;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      min-width: 0;
    }
  }

  .sidebar__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    width: fit-content;
    flex-shrink: 0;
    font-weight: var(--font-weight-medium);
    font-size: var(--step-0);
    color: var(--foreground);
    text-decoration-line: none;

    :global(svg) {
      inline-size: 1.125rem;
      block-size: 1.125rem;
      flex-shrink: 0;

      @media (width < 64rem) {
        display: none;
      }
    }
  }

  nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    min-height: 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    scrollbar-width: none;

    &::-webkit-scrollbar {
      display: none;
    }

    @media (width < 64rem) {
      position: absolute;
      inset-inline: calc(-1 * var(--bar-gutter));
      top: 100%;
      z-index: 10;
      max-height: calc(100svh - 100% - var(--space-m));
      padding: var(--space-xs) var(--bar-gutter) var(--space-s);
      background-color: var(--background);
      border-block-end: 2px solid var(--border);
      box-shadow: 0 12px 24px -12px rgb(0 0 0 / 0.2);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(-0.5rem);
      transition:
        opacity 0.2s ease,
        transform 0.2s ease,
        visibility 0.2s;

      .sidebar[data-menu-open] & {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
        transform: translateY(0);
      }
    }
  }

  .nav-group {
    display: contents;
  }

  .nav-group ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  .nav-group:has(h2) a {
    font-size: var(--step--1);
  }

  .nav-group h2 {
    padding-inline: var(--space-2xs);
    margin-block-end: var(--space-3xs);
    font-size: var(--step-0);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: var(--muted-foreground);
  }

  nav a {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-3xs) var(--space-2xs);
    border-radius: var(--radius-md);
    font-size: var(--step-0);
    color: var(--muted-foreground);
    text-decoration-line: none;

    > svg:first-child {
      flex-shrink: 0;
      inline-size: 1em;
      block-size: 1em;
    }

    > span {
      flex: 1;
      min-width: 0;
    }

    &:hover,
    &[aria-current="page"] {
      color: var(--foreground);
      background-color: var(--muted);
    }
  }

  .sidebar__actions {
    display: flex;
    align-items: center;
    margin-inline-start: -0.5rem;

    @media (width < 64rem) {
      margin-inline-start: 0;
      margin-inline-end: -0.5rem;
    }
  }

  [data-menu-toggle] {
    display: none;

    @media (width < 64rem) {
      display: inline-flex;
    }
  }

  .close-icon {
    display: none;
  }

  .sidebar[data-menu-open] {
    .menu-icon {
      display: none;
    }

    .close-icon {
      display: inline-flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    nav {
      transition: none;
    }
  }
</style>

<script>
  for (const sidebar of document.querySelectorAll<HTMLElement>(
    "[data-sidebar]",
  )) {
    const toggle =
      sidebar.querySelector<HTMLButtonElement>("[data-menu-toggle]")
    const nav = sidebar.querySelector<HTMLElement>("nav")
    if (!toggle || !nav) continue

    const setOpen = (open: boolean) => {
      sidebar.toggleAttribute("data-menu-open", open)
      toggle.setAttribute("aria-expanded", String(open))
      toggle.setAttribute(
        "aria-label",
        open ? "Close navigation" : "Open navigation",
      )
    }
    const closeMenu = () => setOpen(false)

    toggle.addEventListener("click", () =>
      setOpen(!sidebar.hasAttribute("data-menu-open")),
    )

    nav.addEventListener("click", (event) => {
      if (event.target instanceof Element && event.target.closest("a")) {
        closeMenu()
      }
    })

    document.addEventListener("click", (event) => {
      if (
        sidebar.hasAttribute("data-menu-open") &&
        event.target instanceof Node &&
        !sidebar.contains(event.target)
      ) {
        closeMenu()
      }
    })

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && sidebar.hasAttribute("data-menu-open")) {
        closeMenu()
        toggle.focus()
      }
    })

    matchMedia("(width >= 64rem)").addEventListener("change", closeMenu)
  }
</script>
