---
import BookCard from "@/components/library/BookCard.astro"
import type { CollectionEntry } from "astro:content"

type Props = {
  books: CollectionEntry<"books">[]
  showTags?: boolean
  showRating?: boolean
  showDescription?: boolean
  filterable?: boolean
  firstImageLoading?: "eager" | "lazy"
}

const {
  books,
  showTags,
  showRating,
  showDescription,
  filterable,
  firstImageLoading = "lazy",
} = Astro.props
---

<ul>
  {books.map((book, i) => (
    <BookCard
      book={book}
      showTags={showTags}
      showRating={showRating}
      showDescription={showDescription}
      filterable={filterable}
      loading={i === 0 ? firstImageLoading : "lazy"}
    />
  ))}
</ul>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
</style>
