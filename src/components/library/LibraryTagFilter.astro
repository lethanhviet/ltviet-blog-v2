---
import type { BookEntry } from "@/lib/content"

type Props = { books: BookEntry[] }

const { books } = Astro.props

const tags = [...new Set(books.flatMap((book) => book.data.tags ?? []))].sort()
---

<library-tag-filter>
  <div
    data-filters
    role="group"
    aria-label="Filter books by tag"
    hidden={tags.length === 0}
  >
    <button type="button" data-filter-tag="all" aria-pressed="true">All</button>
    {tags.map((tag) => (
      <button type="button" data-filter-tag={tag} aria-pressed="false">
        {tag}
      </button>
    ))}
  </div>
  <slot />
</library-tag-filter>

<style>
  library-tag-filter {
    display: block;
  }

  [data-filters] {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs);
    margin-block-end: var(--space-s);

    button {
      appearance: none;
      padding: 0.2em 0.6em;
      font-size: var(--step--1);
      color: var(--muted-foreground);
      background-color: transparent;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      cursor: pointer;

      &:hover {
        color: var(--foreground);
      }

      &[aria-pressed="true"] {
        color: var(--foreground);
        background-color: var(--muted);
        border-color: var(--muted-foreground);
      }
    }
  }
</style>

<script>
  class LibraryTagFilter extends HTMLElement {
    private controller?: AbortController

    connectedCallback() {
      this.controller?.abort()
      this.controller = new AbortController()
      const { signal } = this.controller
      const buttons = [
        ...this.querySelectorAll<HTMLButtonElement>(
          ":scope > [data-filters] > button",
        ),
      ]
      const items = [
        ...this.querySelectorAll<HTMLLIElement>(":scope > ul > li[data-tags]"),
      ]

      buttons.forEach((button) => {
        button.addEventListener(
          "click",
          () => {
            buttons.forEach((b) =>
              b.setAttribute("aria-pressed", String(b === button)),
            )
            const tag = button.dataset.filterTag
            items.forEach((item) => {
              const tags: string[] = JSON.parse(item.dataset.tags ?? "[]")
              item.hidden = tag !== "all" && !tags.includes(tag ?? "")
            })
          },
          { signal },
        )
      })
    }

    disconnectedCallback() {
      this.controller?.abort()
    }
  }

  if (!customElements.get("library-tag-filter")) {
    customElements.define("library-tag-filter", LibraryTagFilter)
  }
</script>
