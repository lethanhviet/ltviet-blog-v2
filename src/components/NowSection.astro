---
import type { SvgComponent } from "astro/types"
import { renderInline } from "@/lib/utils"

type Props = {
  label: string
  icon: SvgComponent
  items: string[]
}

const { label, icon: Icon, items } = Astro.props
---

{items.length > 0 && (
  <now-section>
    <now-section-label>
      <Icon aria-hidden="true" />
      <span>{label}</span>
    </now-section-label>
    <ul>
      {items.map((item) => <li set:html={renderInline(item)} />)}
    </ul>
  </now-section>
)}

<style>
  now-section {
    display: grid;
    grid-template-columns: calc(2 * var(--grid-column-width) + var(--grid-gutter)) 1fr;
    gap: var(--grid-gutter);
    align-items: start;

    @media (width < 40rem) {
      grid-template-columns: 1fr;
    }
  }

  now-section-label {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2xs);

    @media (width < 40rem) {
      flex-direction: row;
      align-items: center;
    }

    svg {
      inline-size: 1rem;
      block-size: 1rem;
      flex-shrink: 0;
      padding: var(--space-2xs);
      box-sizing: content-box;
      color: var(--foreground);
      background-color: var(--muted);
      border-radius: var(--radius-md);
    }

    span {
      font-size: var(--step--1);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--muted-foreground);
    }
  }

  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    padding-inline-start: 1.1em;
    list-style: disc;
    --underline: var(--muted-foreground);
  }

  li {
    color: var(--foreground);
  }
</style>
