---
import { Image } from "astro:assets"
import type { BookEntry } from "@/lib/content"
import { bookPath } from "@/lib/utils"

type Props = {
  book: BookEntry
  showTags?: boolean
  showRating?: boolean
  showDescription?: boolean
  filterable?: boolean
  loading?: "eager" | "lazy"
}

const {
  book,
  showTags = false,
  showRating = false,
  showDescription = false,
  filterable = false,
  loading = "lazy",
} = Astro.props
const { title, author, cover, tags, description } = book.data
const rating = book.data.status === "finished" ? book.data.rating : undefined
---

<li
  data-tags={filterable ? JSON.stringify(tags ?? []) : undefined}
  data-has-description={showDescription || undefined}
>
  <a href={bookPath(book.id)} data-hover-dim-item>
    <Image
      src={cover}
      alt={`${title} cover`}
      width={64}
      height={96}
      densities={[1, 2, 3]}
      loading={loading}
    />
    <book-heading>
      <span data-title>{title}</span>
      <span data-author>{author}</span>
    </book-heading>
    {(showRating || showTags) && (
      <book-meta>
        {showRating && rating !== undefined && (
          <book-rating role="img" aria-label={`Rated ${rating} out of 5`}>
            {Array.from({ length: 5 }).map((_, i) => (
              <span aria-hidden="true" data-filled={i < rating || undefined} />
            ))}
          </book-rating>
        )}
        {showTags && tags && tags.length > 0 && (
          <book-tags>
            {tags.slice(0, 2).map((tag) => (
              <span>{tag}</span>
            ))}
          </book-tags>
        )}
      </book-meta>
    )}
    {showDescription && <p data-description>{description}</p>}
  </a>
</li>

<style>
  li {
    display: block;
    border-bottom: 1px solid var(--border);
  }

  li:last-child {
    border-bottom: none;
  }

  a {
    display: grid;
    grid-template-columns: calc(
        2 * var(--content-column-width) + var(--grid-gutter)
      ) minmax(0, 1fr) max-content;
    grid-template-areas: "cover heading meta";
    align-items: center;
    column-gap: var(--space-s);
    row-gap: var(--space-3xs);
    padding: var(--space-xs) var(--space-s);
    text-decoration-line: none;

    @media (width < 40rem) {
      grid-template-columns: var(--content-column-width-sm) minmax(0, 1fr) max-content;
    }
  }

  li[data-has-description] a {
    grid-template-areas:
      "cover heading meta"
      "cover description description";

    @media (width < 40rem) {
      grid-template-areas: "cover heading meta";
    }
  }

  img {
    grid-area: cover;
    flex-shrink: 0;
    inline-size: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
  }

  book-heading {
    grid-area: heading;
    display: flex;
    flex-direction: column;
    min-width: 0;

    [data-title] {
      font-size: var(--step-0);
      font-weight: var(--font-weight-medium);
      color: var(--foreground);
    }

    [data-author] {
      font-size: var(--step--1);
      color: var(--muted-foreground);
    }
  }

  book-meta {
    grid-area: meta;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  [data-description] {
    grid-area: description;
    min-width: 0;
    font-size: var(--step-0);
    color: var(--muted-foreground);

    @media (width < 40rem) {
      display: none;
    }
  }

  book-rating {
    flex-shrink: 0;
    inline-size: 3rem;
    display: inline-flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.25em;

    span {
      inline-size: 0.4rem;
      block-size: 0.4rem;
      border-radius: var(--radius-xs);
      background-color: var(--border);

      &[data-filled] {
        background-color: var(--foreground);
      }
    }
  }

  book-tags {
    flex-shrink: 0;
    display: flex;
    justify-content: flex-end;
    gap: var(--space-3xs);
    font-size: var(--step--1);

    @media (width < 40rem) {
      display: none;
    }

    span {
      white-space: nowrap;
      padding: 0.2em 0.6em;
      color: var(--muted-foreground);
      background-color: var(--muted);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
    }
  }
</style>
