---
import type { WritingEntry } from "@/lib/content"
import { formatDate, writingPath } from "@/lib/utils"

type Props = { post: WritingEntry }

const { post } = Astro.props
const { title, description, date, tags = [] } = post.data
---

<li>
  <a href={writingPath(post.id)}>
    <entry-heading>
      <span data-title>{title}</span>
      <entry-meta>
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {tags.length > 0 && (
            <entry-tags>
              {tags.map((tag) => (
                <span>#{tag}</span>
              ))}
            </entry-tags>
          )}
      </entry-meta>
    </entry-heading>
    <p>{description}</p>
  </a>
</li>

<style>
  li {
    display: block;
  }

  a {
    display: block;
    margin-inline: calc(-1 * var(--space-s));
    padding: var(--space-2xs) var(--space-s);
    border-radius: var(--radius-md);
    text-decoration-line: none;
    transition: background-color 0.2s ease;

    &:hover {
      background-color: var(--muted);
    }
  }

  entry-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-2xs);

    @media (width < 40rem) {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-3xs);
    }

    [data-title] {
      font-size: var(--step-1);
      line-height: calc(var(--leading-offset) + 1em);
      font-weight: var(--font-weight-medium);
      color: var(--foreground);
    }

    entry-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: var(--space-2xs);
    }

    time {
      flex-shrink: 0;
      font-size: var(--step--1);
      color: var(--muted-foreground);
    }

    entry-tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-3xs);
      font-size: var(--step--1);

      span {
        color: color-mix(in oklab, var(--muted-foreground) 50%, transparent);
      }
    }
  }

  p {
    margin-block-start: var(--space-3xs);
    color: var(--muted-foreground);
  }
</style>
