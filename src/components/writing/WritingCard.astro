---
import type { WritingEntry } from "@/lib/content"
import { writingPath } from "@/lib/utils"

type Props = {
  post: WritingEntry
  year: number
  showYear: boolean
}

const { post, year, showYear } = Astro.props
const { title, tags = [] } = post.data
const [tag] = tags
---

<li class="writing-row">
  <a href={writingPath(post.id)}>
    <span class="writing-row__year">{showYear && year}</span>
    <span class="writing-row__title">{title}</span>
    {tag && <span class="writing-row__tags">#{tag}</span>}
  </a>
</li>

<style>
  li {
    display: block;
  }

  a {
    display: grid;
    grid-template-columns: calc(
        2 * var(--content-column-width) + var(--grid-gutter)
      ) 1fr auto;
    align-items: baseline;
    gap: var(--space-s);
    padding-block: var(--space-2xs);
    text-decoration-line: none;

    @media (width < 40rem) {
      grid-template-columns: var(--content-column-width-sm) 1fr auto;
      gap: var(--space-2xs);
    }
  }

  .writing-row__year {
    font-size: var(--step--1);
    color: var(--muted-foreground);
  }

  .writing-row__title {
    font-size: var(--step-0);
    color: var(--foreground);
  }

  .writing-row__tags {
    font-size: var(--step--1);
    text-align: right;
    color: color-mix(in oklab, var(--muted-foreground) 50%, transparent);
  }
</style>
