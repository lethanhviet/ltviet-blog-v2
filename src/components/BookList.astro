---
import BookCard from "@/components/BookCard.astro"
import type { CollectionEntry } from "astro:content"

type Props = {
  books: CollectionEntry<"books">[]
  meta?: "none" | "tags" | "rating"
}

const { books, meta } = Astro.props
---

<ul>
  {books.map((book) => <BookCard book={book} meta={meta} />)}
</ul>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }
</style>
